# Gateway runtime env — copy to `.env.gateway.local` (gitignored) and fill in.
# `scripts/start-gateway.sh` sources this file so a restart can't silently drop a
# var (e.g. a missing LEONARDO_NEO4J_PASSWORD used to make search_graph 502).

# ── Access + sessions (SECRETS — must match the deployed web app's env) ──────
# GATEWAY_TOKEN gates every route; the web app sends it as a Bearer token.
# SESSION_SECRET signs the free-tier wallet session tokens. If you rotate these,
# you must redeploy the web app with the same GATEWAY_TOKEN (and users re-auth).
# MCP_TOKEN_SECRET hashes developer MCP tokens; keep distinct from SESSION_SECRET.
GATEWAY_TOKEN=
SESSION_SECRET=
MCP_TOKEN_SECRET=

# ── Metering / owner-lock (TESTNET) ─────────────────────────────────────────
METER=true
# Owner-lock: only this wallet may pay. Keep set until launch. Empty = open.
GATEWAY_PAYER_ALLOWLIST=0xB562Fa73dD449FBd81484EdDd59bA397a7515248
CHAT_PRICE=$0.02
FREE_PROMPTS=5

# ── Repro Lab random-sample lane ────────────────────────────────────────────
# David-only until launch. Set to the same wallet(s) as the web ALLOWED_WALLETS.
# Public responses expose hashed refs/metrics/receipts only; raw runner outputs stay private.
REPRO_LAB_ALLOWED_WALLETS=0xB562Fa73dD449FBd81484EdDd59bA397a7515248
REPRO_LAB_SAMPLE_RUNS_ENABLED=true
REPRO_LAB_MAX_SAMPLE_CASES=12
EVAL_HARNESS_ROOT=/home/exor/SEED-Framework-Evaluation

# ── Chat brain ──────────────────────────────────────────────────────────────
# hermes = the REAL read-only Leonardo agent over ACP (full reasoning + memory +
#          graph via a read-only MCP; bypasses runChatTurn). Recommended.
# codex  = the lightweight in-gateway twin (runChatTurn + gpt-5.4-mini). Fallback.
CHAT_BRAIN=hermes
# --- hermes brain (ACP) ---
LEO_WEB_PROFILE=leonardo-web                      # restricted Hermes profile (setup-profile.sh)
HERMES_VENV_PY=/home/exor/.hermes/hermes-agent/venv/bin/python
LEO_PLATFORM_ROOT=/home/exor/leonardo-platform    # where services/hermes-acp/bridge.py lives
# --- codex twin (only used when CHAT_BRAIN=codex) ---
CHAT_CODEX_MODEL=gpt-5.4-mini
CODEX_CLI_PATH=/home/exor/claw-memory/council-cc/scripts/codex-seat-wrapper.py
LEONARDO_SOUL_PATH=/home/exor/.hermes/profiles/leonardo/SOUL.md

# ── Imagination graph (local, read-only) ────────────────────────────────────
LEONARDO_NEO4J_URI=bolt://localhost:7687
LEONARDO_NEO4J_USER=neo4j
LEONARDO_NEO4J_PASSWORD=<fill-local-neo4j-password>

# ── Deep graph tools (workshop sidecar) ─────────────────────────────────────
WORKSHOP_SIDECAR_URL=http://127.0.0.1:8799

# ── CORS: extra allowed browser origins (localhost + *.vercel.app always ok) ──
GATEWAY_ALLOWED_ORIGINS=https://app.leonardo-ai.io,https://leonardo-ai.io
